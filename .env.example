# Copy to `.env` and edit; loaded by hive_env on startup (override file path with DOTENV_PATH if needed).
# DOTENV_PATH=

# --- Primary LLM endpoint (CLI + web "LM Studio (local)") ---
# Any OpenAI-compatible server. LM Studio: http://127.0.0.1:1234 (no /v1; the client adds it).
# CLI uses this by default. The web UI "LM Studio (local)" profile uses the same pair.
HIVE_BASE_URL=http://127.0.0.1:1234
# Sent as Authorization to that server. LM Studio: any non-empty placeholder (e.g. lm-studio).
HIVE_API_KEY=lm-studio
# CLI only: pin a model id; if unset, first model from GET /v1/models. The web UI ignores this when you pick a model in the form.
# HIVE_MODEL=

# --- Optional second profile: hosted OpenAI (web UI "OpenAI" only) ---
# Leave everything below commented/unset if you only use LM Studio. When set, the web UI can list OpenAI models and run with provider "OpenAI".
# OPENAI_API_KEY=
# Override only if you use a non-default OpenAI-compatible host (default is https://api.openai.com).
# HIVE_OPENAI_BASE_URL=https://api.openai.com

# HTTP read timeout in seconds for each LM Studio native chat request (OpenAI SDK uses its own defaults).
HIVE_HTTP_TIMEOUT_SEC=360
# How many times to retry a failed or rate-limited completion before surfacing the error.
HIVE_LM_RETRY_MAX=5
# Initial backoff in seconds before the first retry (exponential backoff grows from this).
HIVE_LM_RETRY_BASE_DELAY_SEC=1
# Upper cap in seconds on delay between retries (prevents extremely long sleeps).
HIVE_LM_RETRY_MAX_DELAY_SEC=60

# --- Concurrency ---
# Default number of parallel worker threads when not using auto CPU scaling.
HIVE_MAX_PARALLEL_WORKERS=4
# Hard ceiling on worker slots regardless of other settings (also capped internally at 64).
HIVE_MAX_PARALLEL_WORKERS_CAP=16
# If true, scale worker count toward CPU cores up to HIVE_MAX_PARALLEL_WORKERS_CAP.
HIVE_AUTO_PARALLEL_WORKERS=false

# --- Paths ---
# Directory where final hive_result_*.txt files are written.
HIVE_OUTPUT_DIR=hive_outputs
# Parent folder for per-run workspace directories used by tool execution.
HIVE_WORKSPACE_PARENT_DIR=workspace

# --- Knowledge base (user-supplied context directory) ---
# Optional folder of reference files (text-like extensions). When set, a capped index is injected into the
# planner as [User knowledge base] and into worker prompts; workers may call kb_list / kb_read for full content.
# Leave empty to disable. Paths can be absolute or relative to the process cwd (repo root when started from there).
# HIVE_KB_DIR=
# Max total characters of the injected index (head+tail clamp if longer).
# HIVE_KB_INDEX_MAX_CHARS=12000
# Per-file excerpt length inside that index.
# HIVE_KB_INDEX_PER_FILE_HEAD_CHARS=600
# Upper bound for kb_read tool response size (per call); also caps the max_chars the model may request.
# HIVE_KB_READ_MAX_CHARS=40000
# Comma-separated allowed file extensions under the KB root (lowercase, leading dot).
# HIVE_KB_FILE_EXTENSIONS=.md,.txt,.rst,.html,.htm,.json,.yaml,.yml,.csv,.tsv,.py,.js,.ts,.jsx,.tsx,.xml
# Max files scanned for indexing / kb_list (DoS guard).
# HIVE_KB_MAX_FILES=200
# Override folder that contains skill subdirectories (default when unset: ./skills).
# HIVE_SKILLS_DIR=skills
# Override JSON path that stores which skill ids are enabled in the UI (default: ./hive_skills_enabled.json).
# HIVE_SKILLS_ENABLED_FILE=hive_skills_enabled.json

# --- Token and QA budgets ---
# Default max output tokens requested for most LLM roles (per-role multipliers still apply).
HIVE_MAX_TOKENS=150000
# Absolute ceiling after per-role token scaling (responses are clipped to this cap).
HIVE_MAX_TOKENS_CAP=150000
# Maximum worker+QA attempts per task before the run fails that task.
HIVE_MAX_QA_RETRIES=30
# Extra tries when QA output is not valid JSON before giving up on that QA parse.
HIVE_QA_JSON_MAX_RETRIES=2
# Number of QA failures on a task before running an LLM “refinement” pass on the task spec.
HIVE_QA_REFINEMENT_AFTER_FAILURES=10
# On QA retry, include the prior attempt’s tool transcript in the worker prompt (avoid blind re-fetch).
HIVE_QA_RETRY_TOOL_TRACE=true
# Max characters of that transcript injected into the worker user message.
HIVE_QA_RETRY_TOOL_TRACE_MAX_CHARS=18000
# After a QA failure, optionally ask an LLM whether one more shot is enough; if not, run micro-steps then QA.
HIVE_QA_FAIL_DECOMPOSE_ENABLED=false
# Max micro-steps the decompose model may emit (clamped 2–24).
HIVE_QA_FAIL_DECOMPOSE_MAX_STEPS=6
# Run decompose only once the task has reached this QA-attempt index (1 = first QA failure).
HIVE_QA_FAIL_DECOMPOSE_MIN_ATTEMPT=1
# How many times a key-task checkpoint may trigger a replan of remaining work.
HIVE_MAX_CHECKPOINT_REPLANS=3
# Passes for the final consistency reviewer before the run errors or accepts last draft.
HIVE_FINAL_CHECK_ATTEMPTS=3
# How many full-run replans are allowed when the final check demands a replan.
HIVE_REPLAN_ATTEMPTS=2
# When final check requests a full replan, persist merged/task outputs under HIVE_OUTPUT_DIR/run_carryover/<session>/knowledge
# and inject LATEST.md (capped) into the next planner + worker prompts. Disable with false.
HIVE_REPLAN_CARRYOVER_ENABLED=true
# Max characters of LATEST.md injected into prompts per outer replan cycle (head+tail if longer).
HIVE_REPLAN_KNOWLEDGE_MAX_CHARS=36000
# If true, all outer replan cycles of one run_hive() call share one workspace directory so downloaded files survive replans.
HIVE_REPLAN_SHARE_WORKSPACE=false
# Per-task and merged excerpt sizes inside carryover snapshot files (not the same as prompt cap).
HIVE_REPLAN_CARRYOVER_TASK_MAX_CHARS=24000
HIVE_REPLAN_CARRYOVER_MERGED_MAX_CHARS=48000

# --- Planner ---
# Upper bound on the number of tasks the planner may emit in one plan.
HIVE_MAX_PLAN_TASKS=24
# Hint to the planner for how deep dependency chains may go (wording guidance, not a hard graph limit).
HIVE_MAX_PLAN_DEPTH_HINT=8
# Minimum characters required in each task description for plan validation.
HIVE_MIN_TASK_DESCRIPTION_CHARS=20
# Minimum characters required in each task acceptance_criteria for plan validation.
HIVE_MIN_ACCEPTANCE_CRITERIA_CHARS=10
# How many planner critique/repair rounds may run on invalid or weak JSON plans.
HIVE_MAX_PLANNER_CRITIQUE_ROUNDS=2
# If true, use outline-then-expand two-phase planning instead of a single monolithic plan call.
HIVE_USE_TWO_PHASE_PLANNER=true

# --- Merge / synthesis ---
# Max characters of dependency context injected into prompts when summarizing upstream tasks.
HIVE_DEPENDENCY_SUMMARY_MAX_CHARS=4000
# If a dependency blob exceeds this many characters, optionally summarize it with an LLM first.
HIVE_SUMMARIZE_DEPS_LLM_THRESHOLD=8000
# When merged inputs exceed this size in characters, enable merge compression heuristics.
HIVE_MERGER_INPUT_THRESHOLD_CHARS=120000
# Max chunks used when compressing very large merge inputs before the final merger pass.
HIVE_MERGE_COMPRESS_MAX_CHUNKS=8
# Merge strategy name: single_pass (default) or hierarchical for very large inputs.
HIVE_MERGE_STRATEGY=single_pass
# If true, run a final “synthesis” LLM pass to polish the merged answer for the user.
HIVE_FINAL_SYNTHESIS_ENABLED=true
# If true, after each sub-task passes QA, build a strict claims ledger (JSON claims + evidence URLs +
# source_type, numeric_values for pricing, caveats) for merge/final synthesis only. Full task output stays
# in results for downstream workers and checkpoints. Useful for small-context or sliding-window models.
HIVE_POST_QA_ASSERTION_LEDGER=false
# Evidence preset: loose | normal | strict_research | pricing_strict | academic_strict (default normal). Tiers control which
# source_type combinations can verify (e.g. pricing_strict: pricing only from official pricing URLs/calculator).
# academic_strict: blog/news/social cannot verify; adds claim types academic_design | academic_citation | paper_finding |
# academic_sources_only plus source_type academic_metadata (DOI / scholarly URL / publisher-page heuristics).
HIVE_EVIDENCE_POLICY=normal
# Comma-separated allowed evidence source_type strings (empty = preset default set; non-empty overrides allowlist only).
# HIVE_LEDGER_ALLOWED_SOURCE_TYPES=official_pricing_page,official_pricing_calculator,official_docs,academic_paper,academic_metadata,primary_source,news,blog,social,unknown,internal_worker_output
# Resolve same-metric cross-task conflicts on verified claims before merge (official > newer > weaker sources).
HIVE_LEDGER_CONFLICT_RESOLUTION=true
# If true, merger + final synthesis treat only validator-verified claims as facts; appendix for the rest.
# Requires HIVE_POST_QA_ASSERTION_LEDGER=true (otherwise forced off).
HIVE_RESEARCH_VERIFIED_ONLY_FINAL=false
# Multiline or pipe-separated mandatory deliverables; injected into every planner pass and checked at final review.
# HIVE_REQUIRED_DELIVERABLES=
# If true, pricing-type claims must include at least one https?:// source_url in evidence.
HIVE_PRICING_REQUIRES_URL=false
# If true, always write hive_claims_*.json when any claim rows exist; if false, still write when ledger is on and rows exist.
HIVE_SAVE_CLAIMS_REPORT=false
# Max claims included in the web /api/status claims_report snapshot.
HIVE_CLAIMS_REPORT_SNAPSHOT_MAX=80
# If true, run integration QA along critical dependency chains after workers finish.
HIVE_INTEGRATION_QA_ENABLED=true
# If true, integration QA failures can fail the run instead of only logging issues.
HIVE_INTEGRATION_QA_STRICT=false

# --- Tools and run limits ---
# Maximum tool-call rounds inside one worker attempt before stopping tool use and returning text.
HIVE_MAX_TOOL_ROUNDS=8
# Seconds to wait for a single skill subprocess or tool step before timing it out.
HIVE_TOOL_TIMEOUT_SEC=120
# Optional wall-clock limit for an entire run in seconds (empty means no wall-clock limit).
# HIVE_MAX_RUN_WALL_SECONDS=
# Optional rough token budget across the run using character heuristics (empty means unlimited).
# HIVE_MAX_ESTIMATED_TOKENS_PER_RUN=
# Max entries kept for HTTP idempotency deduplication inside tool calls.
HIVE_HTTP_IDEMPOTENCY_MAX_ENTRIES=128
# If true, write the final answer to a timestamped file under HIVE_OUTPUT_DIR.
HIVE_SAVE_FINAL_TO_FILE=true

# --- Prompt compression (workers / QA / router) ---
# Max characters of each dependency task output injected into a downstream worker prompt.
HIVE_DEPENDENCY_OUTPUT_MAX_CHARS=10000
# Max characters of each completed task excerpt shown to the checkpoint LLM.
HIVE_CHECKPOINT_TASK_OUTPUT_CHARS=3500
# If the user problem is shorter than this, workers see it verbatim; otherwise it is compressed.
HIVE_SUBAGENT_PROBLEM_VERBATIM_MAX=5500
# Budget for the middle “excerpt” body when compressing long problems for sub-agents.
HIVE_SUBAGENT_COMPRESSED_BODY_MAX=4200
# How many leading characters of the original problem to keep when compressing.
HIVE_SUBAGENT_HEAD_CHARS=1600
# How many trailing characters of the original problem to keep when compressing.
HIVE_SUBAGENT_TAIL_CHARS=1000

# --- UI logging ---
# Max lines retained in the in-memory status log for the web UI and CLI progress.
HIVE_LOG_MAX_LINES=200
# Max structured LLM I/O records kept for the web UI “io log” view.
HIVE_IO_LOG_MAX_ENTRIES=120

# --- Web UI (Flask) ---
# Default bind address for python agent_hive.py --web (overridable with --host).
HIVE_WEB_HOST=127.0.0.1
# Default TCP port for the Flask UI (overridable with --port).
HIVE_WEB_PORT=5000

# --- test.py (optional) ---
# Prompt text used by test.py when you do not pass a different prompt via env elsewhere.
# HIVE_TEST_PROMPT=Your one-line test prompt here

# --- Tavily search skill ---
# API key for Tavily web search (skill may also read this from its own config).
# TAVILY_API_KEY=
# Alternate env name some deployments use for the same Tavily key.
# HIVE_TAVILY_API_KEY=

# --- telegram_test.py ---
# Bot token from BotFather; required to run telegram_test.py.
# TELEGRAM_BOT_TOKEN=
# If set, send the test message to this chat id without calling getUpdates first.
# TELEGRAM_CHAT_ID=
