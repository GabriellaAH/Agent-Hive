# Sample: 10_openai_web_ui — OpenAI hosted + web UI; set DOTENV_PATH to this file.
# Fill in OPENAI_API_KEY. CLI still uses HIVE_BASE_URL for the default local LM server.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

OPENAI_API_KEY=replace-with-your-openai-api-key
HIVE_OPENAI_BASE_URL=https://api.openai.com

HIVE_WEB_HOST=127.0.0.1
HIVE_WEB_PORT=5000

HIVE_OUTPUT_DIR=hive_outputs/samples/10_openai_web_ui
