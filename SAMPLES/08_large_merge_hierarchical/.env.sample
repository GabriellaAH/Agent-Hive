# Sample: 08_large_merge_hierarchical — large combined merge; set DOTENV_PATH to this file.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_MERGE_STRATEGY=hierarchical
HIVE_MERGER_INPUT_THRESHOLD_CHARS=50000
HIVE_MERGE_COMPRESS_MAX_CHUNKS=10
HIVE_FINAL_SYNTHESIS_ENABLED=true

HIVE_MAX_PLAN_TASKS=14
HIVE_MAX_PARALLEL_WORKERS=4

HIVE_OUTPUT_DIR=hive_outputs/samples/08_large_merge_hierarchical
