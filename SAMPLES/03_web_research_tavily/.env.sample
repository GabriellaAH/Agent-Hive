# Sample: 03_web_research_tavily — set DOTENV_PATH to this file; run from CS_Dashboard root (HIVE_SKILLS_ENABLED_FILE is relative to cwd).

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_SKILLS_ENABLED_FILE=SAMPLES/03_web_research_tavily/hive_skills_enabled.json

HIVE_MAX_TOOL_ROUNDS=12
HIVE_TOOL_TIMEOUT_SEC=180

# Tavily API key (skill scripts read this too). Replace with a real key.
TAVILY_API_KEY=replace-with-your-tavily-api-key

HIVE_OUTPUT_DIR=hive_outputs/samples/03_web_research_tavily
