# Sample: 09_mandatory_deliverables — mandatory deliverables from env; set DOTENV_PATH to this file.
# HIVE_REQUIRED_DELIVERABLES: pipe-separated on one line (parse_deliverables_from_env).

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_REQUIRED_DELIVERABLES=Executive summary (max 120 words)|Mermaid flowchart of main components|Risks and mitigations table (risk, likelihood, impact, action)

HIVE_FINAL_CHECK_ATTEMPTS=4
HIVE_OUTPUT_DIR=hive_outputs/samples/09_mandatory_deliverables
