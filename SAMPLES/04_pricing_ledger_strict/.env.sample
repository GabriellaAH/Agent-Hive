# Sample: 04_pricing_ledger_strict — pricing comparison with strict ledger; set DOTENV_PATH to this file.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_POST_QA_ASSERTION_LEDGER=true
HIVE_EVIDENCE_POLICY=pricing_strict
HIVE_PRICING_REQUIRES_URL=true
HIVE_LEDGER_CONFLICT_RESOLUTION=true
HIVE_SAVE_CLAIMS_REPORT=true

HIVE_MAX_TOOL_ROUNDS=10
HIVE_HTTP_TIMEOUT_SEC=420

HIVE_OUTPUT_DIR=hive_outputs/samples/04_pricing_ledger_strict
