# Sample: 14_outer_replan_shared_workspace — one workspace directory reused across outer replan cycles.
# Set DOTENV_PATH to this file; run from repo root.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_REPLAN_ATTEMPTS=4
HIVE_FINAL_CHECK_ATTEMPTS=3

HIVE_REPLAN_CARRYOVER_ENABLED=true
HIVE_REPLAN_KNOWLEDGE_MAX_CHARS=52000
HIVE_REPLAN_CARRYOVER_TASK_MAX_CHARS=28000
HIVE_REPLAN_CARRYOVER_MERGED_MAX_CHARS=56000

# true: workspace_root = run_carryover/<session>/workspace for every outer cycle in this run_hive() call.
HIVE_REPLAN_SHARE_WORKSPACE=true

HIVE_MAX_TOOL_ROUNDS=12
HIVE_TOOL_TIMEOUT_SEC=180
HIVE_MAX_PLAN_TASKS=18
HIVE_MAX_PARALLEL_WORKERS=4
HIVE_HTTP_TIMEOUT_SEC=420

HIVE_OUTPUT_DIR=hive_outputs/samples/14_outer_replan_shared_workspace
