# Sample: 07_qa_micro_steps — micro-step split after QA failure; set DOTENV_PATH to this file.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_QA_FAIL_DECOMPOSE_ENABLED=true
HIVE_QA_FAIL_DECOMPOSE_MAX_STEPS=8
HIVE_QA_FAIL_DECOMPOSE_MIN_ATTEMPT=1

HIVE_QA_RETRY_TOOL_TRACE=true
HIVE_MAX_QA_RETRIES=24

HIVE_OUTPUT_DIR=hive_outputs/samples/07_qa_micro_steps
