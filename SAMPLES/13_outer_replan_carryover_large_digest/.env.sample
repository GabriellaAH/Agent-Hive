# Sample: 13_outer_replan_carryover_large_digest — outer replan carryover with a very large LATEST.md prompt budget.
# Set DOTENV_PATH to this file; run from repo root.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

# --- Final-check outer replan (requires_replan) ---
HIVE_REPLAN_ATTEMPTS=5
HIVE_FINAL_CHECK_ATTEMPTS=4

# Persist attempt_N.* + LATEST.md under hive_outputs/.../run_carryover/<session>/knowledge (default on; explicit here).
HIVE_REPLAN_CARRYOVER_ENABLED=true
# Large cap: more of LATEST.md is head+tail injected into the next planner + worker prompts after a replan.
HIVE_REPLAN_KNOWLEDGE_MAX_CHARS=100000
# Bigger excerpts inside the snapshot files (still clamped when building LATEST.md sections).
HIVE_REPLAN_CARRYOVER_TASK_MAX_CHARS=32000
HIVE_REPLAN_CARRYOVER_MERGED_MAX_CHARS=64000

# Default: each outer cycle gets a fresh dated workspace folder.
HIVE_REPLAN_SHARE_WORKSPACE=false

HIVE_MAX_PLAN_TASKS=22
HIVE_MAX_PLAN_DEPTH_HINT=10
HIVE_HTTP_TIMEOUT_SEC=480
HIVE_MAX_PARALLEL_WORKERS=4

HIVE_OUTPUT_DIR=hive_outputs/samples/13_outer_replan_carryover_large_digest
