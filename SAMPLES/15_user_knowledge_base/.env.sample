# Sample: 15_user_knowledge_base — HIVE_KB_DIR injects [User knowledge base] + kb_list / kb_read tools.
# Set DOTENV_PATH to this file; run from repo root so HIVE_KB_DIR (relative path) resolves correctly.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

# This sample ships markdown under kb_demo/; index + tools use the same root.
HIVE_KB_DIR=SAMPLES/15_user_knowledge_base/kb_demo

# Slightly larger index than default so three short docs appear in the injected digest.
HIVE_KB_INDEX_MAX_CHARS=10000
HIVE_KB_INDEX_PER_FILE_HEAD_CHARS=900
HIVE_KB_READ_MAX_CHARS=36000
HIVE_KB_MAX_FILES=80
HIVE_KB_FILE_EXTENSIONS=.md,.txt

HIVE_MAX_TOOL_ROUNDS=10
HIVE_HTTP_TIMEOUT_SEC=360
HIVE_MAX_PARALLEL_WORKERS=3

HIVE_OUTPUT_DIR=hive_outputs/samples/15_user_knowledge_base
