# Sample: 11_checkpoint_replan_exploratory — room for multiple mid-run replans at key_task checkpoints.
# Set DOTENV_PATH to this file; run from repo root.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

# Allow several checkpoint-driven replans of not-yet-started tasks (default is often 3).
HIVE_MAX_CHECKPOINT_REPLANS=6
HIVE_MAX_PLAN_TASKS=20
HIVE_MAX_PLAN_DEPTH_HINT=10

# More excerpt text per completed task shown to the checkpoint model.
HIVE_CHECKPOINT_TASK_OUTPUT_CHARS=4500

HIVE_MAX_PARALLEL_WORKERS=4
HIVE_HTTP_TIMEOUT_SEC=420

HIVE_OUTPUT_DIR=hive_outputs/samples/11_checkpoint_replan_exploratory
