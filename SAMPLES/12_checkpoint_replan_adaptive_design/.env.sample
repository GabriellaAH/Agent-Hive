# Sample: 12_checkpoint_replan_adaptive_design — phased design with multiple checkpoint replans.
# Set DOTENV_PATH to this file; run from repo root.

HIVE_BASE_URL=http://127.0.0.1:1234
HIVE_API_KEY=lm-studio

HIVE_MAX_CHECKPOINT_REPLANS=5
HIVE_MAX_PLAN_TASKS=18
HIVE_MAX_PLAN_DEPTH_HINT=9

HIVE_CHECKPOINT_TASK_OUTPUT_CHARS=5000

# Slightly more room if the final reviewer forces a whole-run replan (separate from checkpoint replan).
HIVE_REPLAN_ATTEMPTS=3

HIVE_MAX_PARALLEL_WORKERS=3
HIVE_HTTP_TIMEOUT_SEC=360

HIVE_OUTPUT_DIR=hive_outputs/samples/12_checkpoint_replan_adaptive_design
